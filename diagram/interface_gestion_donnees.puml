@startuml

package "UI" {
  [Sidebar/Navigation] as Sidebar
  [Tableau principal (patients)] as Table
  [Filtres & Recherche] as Filters
  [Dialogues (Ajout/Édition/Import/Export)] as Dialogs
  [Statistiques & Graphiques] as Stats
}

package "Backend" {
  [API Backend] as API
  [Schéma dynamique (JSON)] as Schema<Card
  elevation={0}
  sx={{
    borderRadius: 5,
    border: '1px solid rgba(15, 63, 81, 0.14)',
    background: 'linear-gradient(165deg, rgba(255,255,255,0.98) 
  [Extra Data] as ExtraData
}

Sidebar --> Table
Filters --> Table
Dialogs --> Table
Table --> Stats
Table --> API
Schema --> Table
ExtraData --> Table
API --> Table
Dialogs --> API
Table --> ExtraData
Schema --> Filters

' Sécurité (AuthContext) contrôle tout
actor AuthContext
AuthContext --> Sidebar
AuthContext --> Filters
AuthContext --> Dialogs
AuthContext --> Stats
AuthContext --> Table

@enduml
